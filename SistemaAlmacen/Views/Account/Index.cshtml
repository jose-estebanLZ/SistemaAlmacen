@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_BlankLayout.cshtml";
}

<div class="row vh-100 justify-content-center align-items-center">

    <div class="col-lg-4 col-md-6 col-sm-10">

        <div class="login-card">

            <div class="text-center mb-5">

                <h2 class="login-title">
                    Bienvenido
                </h2>

                <p class="text-muted">
                    Ingrese sus credenciales para continuar
                </p>

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Usuario
                </label>

                <input
                    type="text"
                    class="form-control"
                    placeholder="nombre@ejemplo.com"
                    id="txtUsuario">

            </div>

            <div class="mb-4">

                <div class="d-flex justify-content-between mb-2">

                    <label class="form-label mb-0">
                        Contraseña
                    </label>

                </div>

                <input
                    type="password"
                    class="form-control"
                    placeholder="••••••••"
                    id="txtPassword">

            </div>

            <button class="btn btn-login w-100" onclick="validarInicioSesion()">
                Iniciar Sesión
            </button>

            <div class="version-divider my-4 text-center border-top">

                <span class="mt-2">v 1.0.0</span>

            </div>
        </div>

    </div>

</div>

<script>
    function validarInicioSesion(){
        
        const user = document.getElementById('txtUsuario').value;
        const pass = document.getElementById('txtPassword').value;
        
        fetch(`@Url.Action("ValidarInicioSesion", "Account")?nombreUsuario=${user}&contraseña=${pass}`, {
            method: 'POST'
        })
            .then(response => {
                console.log(response);
                if(response.status == 200){
                    window.location.href = '@Url.Action("Index", "Product")';
                    return;
                }
                
                alert('Usuario y/o contraseña incorrectos.');
            })
            .catch(error => {
                console.error("Error en la petición:", error);
            });
    }
</script>
